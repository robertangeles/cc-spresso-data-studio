{
  "name": "cc-content-builder",
  "version": "0.1.0",
  "private": true,
  "description": "World-class content builder with multi-model AI support",
  "scripts": {
    "predev": "npx kill-port 3003 5173 5174 || exit 0",
    "dev": "pnpm -r --parallel dev",
    "build": "rm -f packages/shared/tsconfig.tsbuildinfo && pnpm -C packages/shared build && pnpm -C packages/server build && pnpm -C packages/client build",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "lint:fix": "eslint packages/*/src --ext .ts,.tsx --fix",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,css}\"",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @cc/server db:generate",
    "db:migrate": "pnpm --filter @cc/server db:migrate",
    "db:push": "pnpm --filter @cc/server db:push",
    "db:studio": "pnpm --filter @cc/server db:studio",
    "clean": "pnpm -r exec rm -rf dist node_modules && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild",
      "es5-ext"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
