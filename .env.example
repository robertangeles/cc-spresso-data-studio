# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cc_content_builder

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Token Encryption (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, tokens are stored in plaintext (not recommended for production)
TOKEN_ENCRYPTION_KEY=

# AI Providers (Phase 2)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# XAI_API_KEY=
# GEMINI_API_KEY=
# MISTRAL_API_KEY=

# Model Studio — Step-gated feature flags.
# Flip to `true` once the Step has shipped and verified.
# Default ON since 2026-04-21 — leave as kill switch for production rollback.
MODEL_STUDIO_RELATIONSHIPS_ENABLED=true
